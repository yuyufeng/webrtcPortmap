# WebRTC PortMap Signaling 启动参数（一行写全，systemd 会按空白拆分）
# 修改后执行：systemctl restart signaling
#
# 必改项：
#   -turn-public-ip   改成本机对外可达的公网 IP（否则 TURN 中继候选不可用）
#   -turn-secret      改成一串随机长字符串（务必固定，否则重启后旧凭据失效）
#
# 不需要 TURN 中转：删掉 -turn-* 与 -admin-config 即可。

SIGNALING_ARGS=-addr 0.0.0.0:8443 -data /var/lib/webrtc-portmap/signaling.json -turn-enabled -turn-public-ip 1.95.54.7 -turn-port 3478 -turn-secret CHANGE_ME_TO_A_LONG_RANDOM_SECRET -admin-config /etc/webrtc-portmap/admins.json
